# Copy to .env and fill in.

# Telegram bot token from @BotFather
BOT_TOKEN=

# Target group chat id where summaries are posted.
# Add the bot to the group, then send /chatid in the group to get this value
# (group ids are negative, e.g. -1001234567890).
GROUP_CHAT_ID=

# Postgres connection (read-only is enough). Local dev points at the dockerised DB.
DATABASE_URL=postgresql://crm:crm_password_2026@localhost:5433/crm

# Link to the board shown in summaries
BOARD_URL=https://crm.01academy.uz/management

# Timezone for the schedule and date math
TZ=Asia/Tashkent
